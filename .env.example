# База данных (общая для портала — писать строку целиком, без интерполяции ${})
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ISR on-demand revalidation secret
REVALIDATE_SECRET=""   # openssl rand -base64 32

# S3
S3_ENDPOINT=""         # хост без протокола: s3.firstvds.ru
S3_REGION="default"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
NEXT_PUBLIC_S3_BASE_URL=""  # https://<S3_ENDPOINT>/<S3_BUCKET>

# NextAuth
NEXTAUTH_SECRET=""     # openssl rand -base64 32
NEXTAUTH_URL="https://art.ph1l74.com"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
ADMIN_ALLOWLIST=""

# Аналитика (Яндекс.Метрика) — ID счётчика (число, не строка)
NEXT_PUBLIC_YANDEX_METRIKA_ID=""

# Аналитика (Google Analytics 4) — формат G-XXXXXXXX
NEXT_PUBLIC_GA_ID=""

# Публичный URL сайта без завершающего слэша — используется для OG canonical URL
